<Window x:Class="SonarDataPlayer.App.NewProjectWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="New Sonar Project"
        Height="560"
        Width="760"
        MinHeight="520"
        MinWidth="700"
        WindowStartupLocation="CenterOwner"
        Background="#101318">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Create Project"
                       Foreground="#EEF2F7"
                       FontSize="20"
                       FontWeight="SemiBold" />
            <TextBlock Text="Convert Garmin RSD or Lowrance SL2/SL3 recordings through the configured PINGverter checkout."
                       Foreground="#8E9AAD"
                       Margin="0,4,0,16" />
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="96" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="Input file"
                       Foreground="#D7DEE8"
                       VerticalAlignment="Center" />
            <TextBox x:Name="InputFileText"
                     Grid.Column="1"
                     Height="30"
                     Margin="0,0,10,0" />
            <Button Grid.Column="2"
                    Height="30"
                    Content="Browse..."
                    Click="BrowseInput_Click" />
        </Grid>

        <Grid Grid.Row="2" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="96" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="Projects root"
                       Foreground="#D7DEE8"
                       VerticalAlignment="Center" />
            <TextBox x:Name="ProjectsRootText"
                     Grid.Column="1"
                     Height="30"
                     Margin="0,0,10,0" />
            <Button Grid.Column="2"
                    Height="30"
                    Content="Browse..."
                    Click="BrowseOutput_Click" />
        </Grid>

        <Grid Grid.Row="3" Margin="0,0,0,14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Row="0"
                       Grid.Column="0"
                       Text="Generated folder"
                       Foreground="#D7DEE8"
                       VerticalAlignment="Center" />
            <TextBlock x:Name="GeneratedFolderText"
                       Grid.Row="0"
                       Grid.Column="1"
                       Foreground="#8E9AAD"
                       TextTrimming="CharacterEllipsis"
                       VerticalAlignment="Center" />
            <TextBlock Grid.Row="1"
                       Grid.Column="0"
                       Text="PINGverter"
                       Foreground="#D7DEE8"
                       Margin="0,8,0,0"
                       VerticalAlignment="Center" />
            <TextBlock x:Name="PingverterRootText"
                       Grid.Row="1"
                       Grid.Column="1"
                       Foreground="#8E9AAD"
                       Margin="0,8,0,0"
                       TextTrimming="CharacterEllipsis"
                       VerticalAlignment="Center" />
        </Grid>

        <Border Grid.Row="4"
                BorderBrush="#2B3442"
                BorderThickness="1"
                Background="#151A21"
                Padding="10">
            <TextBox x:Name="OutputText"
                     Background="#0A0D12"
                     Foreground="#D7DEE8"
                     FontFamily="Consolas"
                     FontSize="12"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto" />
        </Border>

        <DockPanel Grid.Row="5" Margin="0,16,0,0">
            <CheckBox x:Name="OpenProjectCheck"
                      DockPanel.Dock="Left"
                      VerticalAlignment="Center"
                      IsChecked="True"
                      Foreground="#D7DEE8"
                      Content="Open project when complete" />

            <StackPanel DockPanel.Dock="Right"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Width="92"
                        Height="34"
                        Margin="0,0,10,0"
                        Content="Close"
                        Click="Close_Click" />
                <Button x:Name="ProcessButton"
                        Width="148"
                        Height="34"
                        Content="Process Recording"
                        Click="Process_Click" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
