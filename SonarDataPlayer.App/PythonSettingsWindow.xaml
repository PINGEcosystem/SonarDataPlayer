<Window x:Class="SonarDataPlayer.App.PythonSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Python Settings"
        Height="360"
        Width="640"
        MinHeight="340"
        MinWidth="580"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#101318">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Python Source"
                       Foreground="#EEF2F7"
                       FontSize="18"
                       FontWeight="SemiBold" />
            <TextBlock Text="Choose which Python interpreter SonarDataPlayer should try first when creating projects."
                       Foreground="#8E9AAD"
                       Margin="0,4,0,14" />
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="Environment"
                       Foreground="#D7DEE8"
                       VerticalAlignment="Center" />
            <TextBox x:Name="EnvPathText"
                     Grid.Column="1"
                     Height="30"
                     IsReadOnly="True" />
        </Grid>

        <Grid Grid.Row="2" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="90" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="Python path"
                       Foreground="#D7DEE8"
                       VerticalAlignment="Center" />
            <TextBox x:Name="PythonPathText"
                     Grid.Column="1"
                     Height="30"
                     Margin="0,0,10,0" />
            <Button Grid.Column="2"
                    Height="30"
                    Content="Browse..."
                    Click="Browse_Click" />
        </Grid>

        <Border Grid.Row="3"
                BorderBrush="#2B3442"
                BorderThickness="1"
                Background="#151A21"
                Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0"
                            Orientation="Horizontal"
                            Margin="0,0,0,12">
                    <RadioButton x:Name="UseEnvRadio"
                                 Content="Use environment variable"
                                 Foreground="#D7DEE8"
                                 Margin="0,0,24,0" />
                    <RadioButton x:Name="UsePathRadio"
                                 Content="Use saved path"
                                 Foreground="#D7DEE8" />
                </StackPanel>

                <TextBox x:Name="TestOutputText"
                         Grid.Row="1"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto" />
            </Grid>
        </Border>

        <DockPanel Grid.Row="4" Margin="0,16,0,0">
            <Button DockPanel.Dock="Left"
                    Width="96"
                    Height="32"
                    Content="Test"
                    Click="Test_Click" />
            <StackPanel DockPanel.Dock="Right"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Width="90"
                        Height="32"
                        Margin="0,0,10,0"
                        Content="Cancel"
                        Click="Cancel_Click" />
                <Button Width="90"
                        Height="32"
                        Content="Save"
                        Click="Save_Click" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
