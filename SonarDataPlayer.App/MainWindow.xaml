<Window x:Class="SonarDataPlayer.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sonar Data Player v0.1.4"
        Height="820"
        MinHeight="620"
        Width="1280"
        MinWidth="980"
        Background="#101318">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56" />
            <RowDefinition Height="*" />
            <RowDefinition Height="92" />
            <RowDefinition Height="104" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#171B22" BorderBrush="#242B36" BorderThickness="0,0,0,1">
            <DockPanel LastChildFill="True" Margin="16,0">
                <Button DockPanel.Dock="Left"
                        Width="124"
                        Height="34"
                        Margin="0,0,14,0"
                        Click="OpenManifest_Click"
                        Content="Open Project" />
                <TextBlock x:Name="RecordingTitle"
                           VerticalAlignment="Center"
                           Foreground="#EEF2F7"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Text="No recording loaded" />
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="v0.1.4"
                               Foreground="#8E9AAD"
                               VerticalAlignment="Center"
                               Margin="0,0,18,0" />
                    <RadioButton x:Name="StackedMode"
                                 Content="Stacked"
                                 Foreground="#D7DEE8"
                                 IsChecked="True"
                                 Checked="ViewMode_Checked"
                                 Margin="0,0,14,0" />
                    <RadioButton x:Name="OverlayMode"
                                 Content="Overlay"
                                 Checked="ViewMode_Checked"
                                 Foreground="#D7DEE8" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="280" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    BorderBrush="#2B3442"
                    BorderThickness="1"
                    Background="#05070A">
                <Grid>
                    <Grid x:Name="ViewerHost"
                          Margin="8"
                          SizeChanged="ViewerHost_SizeChanged" />

                    <TextBlock x:Name="EmptyViewerText"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="#8E9AAD"
                               FontSize="18"
                               Text="Open a processed sonar project manifest to begin playback." />
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    Margin="14,0,0,0"
                    Padding="14"
                    BorderBrush="#2B3442"
                    BorderThickness="1"
                    Background="#151A21">
                <StackPanel>
                    <TextBlock Text="Channels"
                               Foreground="#EEF2F7"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Margin="0,0,0,10" />
                    <ItemsControl x:Name="ChannelControls">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="82" />
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Content="{Binding Label}"
                                              Foreground="#D7DEE8"
                                              IsChecked="{Binding IsVisible}" />
                                    <Slider Grid.Column="1"
                                            Minimum="0"
                                            Maximum="1"
                                            Value="{Binding Opacity}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Separator Margin="0,12,0,14" Background="#2B3442" />

                    <TextBlock Text="Units"
                               Foreground="#EEF2F7"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Margin="0,0,0,10" />

                    <TextBlock Text="Depth"
                               Foreground="#8E9AAD"
                               Margin="0,0,0,4" />
                    <ComboBox x:Name="DepthUnitSelector"
                              Height="32"
                              SelectedIndex="1"
                              SelectionChanged="UnitSelector_SelectionChanged"
                              Margin="0,0,0,10">
                        <ComboBoxItem Content="Feet" Tag="Feet" />
                        <ComboBoxItem Content="Meters" Tag="Meters" />
                        <ComboBoxItem Content="Fathoms" Tag="Fathoms" />
                    </ComboBox>

                    <TextBlock Text="Speed"
                               Foreground="#8E9AAD"
                               Margin="0,0,0,4" />
                    <ComboBox x:Name="SpeedUnitSelector"
                              Height="32"
                              SelectedIndex="0"
                              SelectionChanged="UnitSelector_SelectionChanged">
                        <ComboBoxItem Content="MPH" Tag="Mph" />
                        <ComboBoxItem Content="Knots" Tag="Knots" />
                    </ComboBox>

                    <TextBlock Text="Water Temp"
                               Foreground="#8E9AAD"
                               Margin="0,10,0,4" />
                    <ComboBox x:Name="TemperatureUnitSelector"
                              Height="32"
                              SelectedIndex="0"
                              SelectionChanged="UnitSelector_SelectionChanged">
                        <ComboBoxItem Content="Celsius" Tag="Celsius" />
                        <ComboBoxItem Content="Fahrenheit" Tag="Fahrenheit" />
                    </ComboBox>

                    <TextBlock Text="UTC Offset"
                               Foreground="#8E9AAD"
                               Margin="0,10,0,4" />
                    <ComboBox x:Name="UtcOffsetSelector"
                              Height="32"
                              SelectedIndex="1"
                              SelectionChanged="UnitSelector_SelectionChanged">
                        <ComboBoxItem Content="UTC-5" Tag="-5" />
                        <ComboBoxItem Content="UTC-4 DST" Tag="-4" />
                        <ComboBoxItem Content="UTC" Tag="0" />
                    </ComboBox>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="#171B22" BorderBrush="#242B36" BorderThickness="0,1">
            <Grid Margin="16,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="88" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="112" />
                    <ColumnDefinition Width="96" />
                    <ColumnDefinition Width="120" />
                </Grid.ColumnDefinitions>

                <Button x:Name="PlayPauseButton"
                        Width="72"
                        Height="34"
                        Click="PlayPause_Click"
                        Content="Play" />
                <Slider x:Name="SeekSlider"
                        Grid.Column="1"
                        Minimum="0"
                        Maximum="1"
                        ValueChanged="SeekSlider_ValueChanged"
                        Margin="10,0" />
                <ComboBox x:Name="ZoomSelector"
                          Grid.Column="2"
                          Height="32"
                          SelectedIndex="0"
                          SelectionChanged="ZoomSelector_SelectionChanged">
                    <ComboBoxItem Content="Full" Tag="0" />
                    <ComboBoxItem Content="+/- 120s" Tag="240" />
                    <ComboBoxItem Content="+/- 60s" Tag="120" />
                    <ComboBoxItem Content="+/- 30s" Tag="60" />
                    <ComboBoxItem Content="+/- 10s" Tag="20" />
                </ComboBox>
                <ComboBox x:Name="RateSelector"
                          Grid.Column="3"
                          Height="32"
                          SelectedIndex="2"
                          SelectionChanged="RateSelector_SelectionChanged">
                    <ComboBoxItem Content="0.25x" Tag="0.25" />
                    <ComboBoxItem Content="0.5x" Tag="0.5" />
                    <ComboBoxItem Content="1x" Tag="1" />
                    <ComboBoxItem Content="2x" Tag="2" />
                    <ComboBoxItem Content="4x" Tag="4" />
                </ComboBox>
                <TextBlock x:Name="TimeReadout"
                           Grid.Column="4"
                           VerticalAlignment="Center"
                           Foreground="#D7DEE8"
                           TextAlignment="Right"
                           Text="0.0 / 0.0 s" />
            </Grid>
        </Border>

        <UniformGrid Grid.Row="3"
                     Columns="8"
                     Margin="16,10">
            <TextBlock x:Name="DateTimeReadout" Foreground="#EEF2F7" FontSize="15" FontWeight="SemiBold" Text="Time: -" />
            <TextBlock x:Name="DepthReadout" Foreground="#EEF2F7" FontSize="15" FontWeight="SemiBold" Text="Depth: -" />
            <TextBlock x:Name="RangeReadout" Foreground="#EEF2F7" FontSize="15" FontWeight="SemiBold" Text="Range: -" />
            <TextBlock x:Name="PositionReadout" Foreground="#EEF2F7" FontSize="15" FontWeight="SemiBold" Text="Position: -" />
            <TextBlock x:Name="SpeedReadout" Foreground="#EEF2F7" FontSize="15" FontWeight="SemiBold" Text="Speed: -" />
            <TextBlock x:Name="HeadingReadout" Foreground="#EEF2F7" FontSize="15" FontWeight="SemiBold" Text="Heading: -" />
            <TextBlock x:Name="TempReadout" Foreground="#EEF2F7" FontSize="15" FontWeight="SemiBold" Text="Water Temp: -" />
            <TextBlock x:Name="PingReadout" Foreground="#EEF2F7" FontSize="15" FontWeight="SemiBold" Text="Ping: -" />
        </UniformGrid>
    </Grid>
</Window>
